      </div>
      <div class="stat-card glass">
        <div class="number" id="statPorts">65,535</div>
        <div class="label">Ports Observed</div>
        <div class="trend">—</div>
      </div>
      <div class="stat-card glass">
        <div class="number" id="statPing">12 ms</div>
        <div class="label">Avg Response</div>
        <div class="trend">↓ 0.3 ms</div>
      </div>
      <div class="stat-card glass">
        <div class="number" id="statPackets">1.25M</div>
        <div class="label">Packets Visualized</div>
        <div class="trend">↑ 12.4%</div>
      </div>
    </div>
  </section>

  <!-- ========== SCANNER CONSOLE ========== -->
  <section id="console">
    <h2 class="section-title"><span>📡 Scanner Console</span></h2>
    <p class="section-sub">Simulated network visualization engine – typing effect.</p>
    <div class="glass" style="padding: 10px;">
      <div class="console" id="consoleOutput">
        <div class="line"><span class="prompt">$</span> Initializing visualization...</div>
        <div class="line"><span class="prompt">$</span> Loading world database...</div>
