<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FlashMap – Internet Scale Visualization</title>
  <style>
    /* ----- Reset & Base ----- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html {
      scroll-behavior: smooth;
    }
    body {
      background: #050816;
      color: #d0e0ff;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      overflow-x: hidden;
      line-height: 1.6;
    }
    a {
      color: #00E5FF;
      text-decoration: none;
    }

    /* ----- Scrollbar ----- */
    ::-webkit-scrollbar {
      width: 6px;
      background: #0b1428;
    }
    ::-webkit-scrollbar-thumb {
      background: #00E5FF;
      border-radius: 20px;
      box-shadow: 0 0 20px #00E5FF66;
    }

    /* ----- Navbar (Sticky Glass) ----- */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      padding: 12px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(5, 8, 22, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0, 229, 255, 0.08);
      z-index: 999;
      transition: 0.3s;
    }
    .navbar .logo {
      font-weight: 700;
      font-size: 1.4rem;
      letter-spacing: 0.05em;
      background: linear-gradient(135deg, #00E5FF, #7BFF00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .navbar .logo span {
      color: #7BFF00;
      -webkit-text-fill-color: #7BFF00;
    }
    .nav-links {
      display: flex;
      gap: 28px;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      color: #8899cc;
      transition: 0.3s;
      position: relative;
    }
    .nav-links a:hover {
      color: #00E5FF;
      text-shadow: 0 0 20px #00E5FF66;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: #00E5FF;
      transition: 0.3s;
      box-shadow: 0 0 12px #00E5FF;
    }
    .nav-links a:hover::after {
      width: 100%;
    }
    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
    }
    .menu-toggle span {
      width: 28px;
      height: 2px;
      background: #00E5FF;
      border-radius: 4px;
      transition: 0.3s;
    }

    /* ----- Hero (Fullscreen with Canvas) ----- */
    #hero {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    #hero canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      padding: 20px;
      background: rgba(5, 8, 22, 0.3);
      backdrop-filter: blur(4px);
      border-radius: 40px;
      border: 1px solid rgba(0, 229, 255, 0.08);
      padding: 40px 50px;
    }
    .hero-content h1 {
      font-size: 4.2rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      background: linear-gradient(135deg, #00E5FF, #7BFF00, #8A6EFF);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 0 80px rgba(0, 229, 255, 0.15);
      margin-bottom: 12px;
    }
    .hero-content p {
      font-size: 1.4rem;
      font-weight: 300;
      color: #a0b8dd;
      letter-spacing: 0.15em;
      margin-bottom: 24px;
    }
    .hero-badge {
      display: inline-block;
      padding: 6px 22px;
      border: 1px solid rgba(0, 229, 255, 0.2);
      border-radius: 40px;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: #00E5FF;
      backdrop-filter: blur(4px);
      margin-bottom: 20px;
    }
    .btn-group {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      padding: 12px 34px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: 0.3s;
      border: 1px solid #00E5FF;
      color: #00E5FF;
      background: transparent;
      backdrop-filter: blur(4px);
    }
    .btn:hover {
      background: #00E5FF;
      color: #050816;
      box-shadow: 0 0 40px #00E5FF77;
      transform: scale(1.04);
    }
    .btn-secondary {
      border-color: #8A6EFF;
      color: #8A6EFF;
    }
    .btn-secondary:hover {
      background: #8A6EFF;
      color: #050816;
      box-shadow: 0 0 40px #8A6EFF77;
    }

    /* ----- Common Sections ----- */
    section {
      padding: 80px 20px;
      position: relative;
      max-width: 1280px;
      margin: 0 auto;
    }
    .section-title {
      font-size: 2.8rem;
      font-weight: 300;
      text-align: center;
      margin-bottom: 16px;
      letter-spacing: 0.02em;
    }
    .section-title span {
      background: linear-gradient(135deg, #00E5FF, #7BFF00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .section-sub {
      text-align: center;
      color: #8899bb;
      font-size: 1.1rem;
      max-width: 700px;
      margin: 0 auto 50px;
    }

    /* ----- Glass Card ----- */
    .glass {
      background: rgba(5, 8, 22, 0.5);
      backdrop-filter: blur(12px) saturate(180%);
      -webkit-backdrop-filter: blur(12px) saturate(180%);
      border: 1px solid rgba(0, 229, 255, 0.08);
      border-radius: 28px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6), inset 0 0 80px rgba(0, 229, 255, 0.02);
      transition: 0.4s;
    }
    .glass:hover {
      border-color: rgba(0, 229, 255, 0.25);
      box-shadow: 0 8px 60px rgba(0, 229, 255, 0.06);
    }

    /* ----- Live Map (Canvas) ----- */
    #live-map {
      padding-top: 40px;
    }
    #map-canvas {
      width: 100%;
      height: 500px;
      border-radius: 28px;
      border: 1px solid rgba(0, 229, 255, 0.08);
      background: #050816;
      display: block;
    }

    /* ----- Statistics Cards ----- */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-top: 30px;
    }
    .stat-card {
      padding: 28px 20px;
      text-align: center;
      border: 1px solid rgba(0, 229, 255, 0.06);
      border-radius: 24px;
      background: rgba(5, 8, 22, 0.4);
      backdrop-filter: blur(4px);
    }
    .stat-card .number {
      font-size: 2.6rem;
      font-weight: 300;
      background: linear-gradient(135deg, #00E5FF, #7BFF00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-family: 'Courier New', monospace;
    }
    .stat-card .label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #8899bb;
      margin-top: 8px;
    }
    .stat-card .trend {
      font-size: 0.8rem;
      color: #7BFF00;
      margin-top: 8px;
    }

    /* ----- Scanner Console ----- */
    .console {
      background: #0b1428;
      border: 1px solid rgba(0, 229, 255, 0.1);
      border-radius: 16px;
      padding: 24px 28px;
      font-family: 'Courier New', monospace;
      font-size: 0.95rem;
      color: #a0b8dd;
      min-height: 160px;
      box-shadow: 0 0 60px rgba(0, 229, 255, 0.02);
      margin-top: 30px;
    }
    .console .line {
      padding: 4px 0;
    }
    .console .prompt {
      color: #00E5FF;
    }
    .console .cursor {
      display: inline-block;
      width: 10px;
      height: 1.2em;
      background: #00E5FF;
      animation: blink 1s step-end infinite;
      vertical-align: text-bottom;
      margin-left: 2px;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* ----- Heatmap ----- */
    .heatmap-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }
    .heat-region {
      padding: 30px 16px;
      border-radius: 20px;
      text-align: center;
      background: rgba(0, 229, 255, 0.02);
      border: 1px solid rgba(0, 229, 255, 0.04);
      transition: 0.3s;
      position: relative;
      overflow: hidden;
    }
    .heat-region::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at center, rgba(0, 229, 255, 0.05), transparent 70%);
      animation: pulseGlow 3s infinite alternate ease-in-out;
    }
    @keyframes pulseGlow {
      0% { opacity: 0.3; transform: scale(0.9); }
      100% { opacity: 1; transform: scale(1.2); }
    }
    .heat-region .region-name {
      font-weight: 600;
      color: #d0e0ff;
      position: relative;
    }
    .heat-region .region-value {
      font-size: 1.6rem;
      font-weight: 300;
      color: #00E5FF;
      position: relative;
    }

    /* ----- Charts (Canvas) ----- */
    #chart-canvas {
      width: 100%;
      height: 320px;
      border-radius: 20px;
      border: 1px solid rgba(0, 229, 255, 0.05);
      background: #0b1428;
      margin-top: 20px;
    }

    /* ----- Satellite Panel ----- */
    .satellite-panel {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      align-items: center;
      margin-top: 30px;
    }
    .satellite-visual {
      text-align: center;
      padding: 30px;
    }
    .satellite-visual .orbit-icon {
      font-size: 5rem;
      display: block;
      animation: orbitSpin 8s linear infinite;
    }
    @keyframes orbitSpin {
      0% { transform: rotate(0deg) scale(1); }
      100% { transform: rotate(360deg) scale(1); }
    }
    .satellite-data {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .sat-data-item {
      background: rgba(0, 229, 255, 0.02);
      padding: 16px;
      border-radius: 16px;
      border: 1px solid rgba(0, 229, 255, 0.04);
      text-align: center;
    }
    .sat-data-item .label {
      font-size: 0.7rem;
      text-transform: uppercase;
      color: #8899bb;
    }
    .sat-data-item .value {
      font-size: 1.4rem;
      font-weight: 300;
      color: #00E5FF;
      font-family: 'Courier New', monospace;
    }

    /* ----- Footer ----- */
    footer {
      border-top: 1px solid rgba(0, 229, 255, 0.05);
      padding: 40px 20px 30px;
      text-align: center;
      color: #4a5a7a;
      font-size: 0.9rem;
      max-width: 1280px;
      margin: 0 auto;
    }
    footer .footer-brand {
      font-size: 1.2rem;
      font-weight: 600;
      color: #00E5FF;
      letter-spacing: 0.05em;
    }

    /* ----- Responsive ----- */
    @media (max-width: 768px) {
      .navbar {
        padding: 12px 20px;
      }
      .nav-links {
        display: none;
        flex-direction: column;
        background: rgba(5, 8, 22, 0.95);
        backdrop-filter: blur(16px);
        position: absolute;
        top: 60px;
        left: 0;
        width: 100%;
        padding: 20px;
        gap: 16px;
        border-bottom: 1px solid rgba(0, 229, 255, 0.05);
      }
      .nav-links.open {
        display: flex;
      }
      .menu-toggle {
        display: flex;
      }
      .hero-content h1 {
        font-size: 2.6rem;
      }
      .hero-content p {
        font-size: 1.1rem;
      }
      .hero-content {
        padding: 30px 20px;
      }
      .section-title {
        font-size: 2rem;
      }
      .satellite-panel {
        grid-template-columns: 1fr;
      }
      #map-canvas {
        height: 300px;
      }
      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 480px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }
      .heatmap-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>
<body>

  <!-- ========== NAVBAR ========== -->
  <nav class="navbar" id="navbar">
    <div class="logo">FLASH<span>MAP</span></div>
    <ul class="nav-links" id="navLinks">
      <li><a href="#hero">Home</a></li>
      <li><a href="#live-map">Live Scan</a></li>
      <li><a href="#world-map">World Map</a></li>
      <li><a href="#analytics">Analytics</a></li>
      <li><a href="#statistics">Statistics</a></li>
      <li><a href="#docs">Documentation</a></li>
    </ul>
    <button class="menu-toggle" id="menuToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- ========== HERO ========== -->
  <section id="hero">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-content">
      <div class="hero-badge">🛰 SATELLITE CYBER INTELLIGENCE</div>
      <h1>FLASHMAP</h1>
      <p>Internet Scale Visualization Scanner</p>
      <p style="font-size: 1rem; color: #8A6EFF; letter-spacing: 0.2em; margin-bottom: 24px;">
        Observe • Discover • Analyze
      </p>
      <div class="btn-group">
        <a href="#live-map" class="btn">⟳ Launch Scan</a>
        <a href="#analytics" class="btn btn-secondary">Explore Data</a>
      </div>
    </div>
  </section>

  <!-- ========== LIVE INTERNET MAP ========== -->
  <section id="live-map">
    <h2 class="section-title"><span>🌍 Live Internet Map</span></h2>
    <p class="section-sub">Real‑time visualization of global network activity – simulated for educational demonstration.</p>
    <canvas id="map-canvas"></canvas>
  </section>

  <!-- ========== STATISTICS ========== -->
  <section id="statistics">
    <h2 class="section-title"><span>📊 Live Statistics</span></h2>
    <p class="section-sub">Animated global network metrics – updated in real‑time.</p>
    <div class="stats-grid">
      <div class="stat-card glass">
        <div class="number" id="statIPv4">4.29B</div>
        <div class="label">IPv4 Space</div>
        <div class="trend">↑ 0.02%</div>
      </div>
      <div class="stat-card glass">
        <div class="number" id="statHosts">18M</div>
